generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                     String   @id @default(cuid())
  name                   String?
  email                  String?  @unique
  role                   Role     @default(USER)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  canManageAdmins        Boolean  @default(false)
  canManageConsultations Boolean  @default(false)
  canManagePosts         Boolean  @default(false)
  isActive               Boolean  @default(true)
  memo                   String?
  password               String?
}

model Lead {
  id            String     @id @default(cuid())
  name          String
  phone         String
  debtAmount    String?
  preferredType String?
  content       String?
  status        LeadStatus @default(PENDING)
  source        String?
  extraInfo     Json?
  isEncrypted   Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  location      String?
}

model CaseStatus {
  id         String   @id @default(cuid())
  region     String
  clientName String
  caseType   String
  milestone  String
  isPublic   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model Consultation {
  id        String    @id @default(cuid())
  type      String
  name      String
  phone     String
  location  String?
  category  String?
  visitDate DateTime?
  visitTime String?
  content   String?
  status    String    @default("PENDING")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model BoardQna {
  id           String   @id @default(cuid())
  author       String
  password     String
  phone        String
  email        String?
  location     String?
  title        String
  content      String
  status       String   @default("PENDING")
  createdAt    DateTime @default(now())
  isSecret     Boolean  @default(true)
  replyContent String?
  updatedAt    DateTime @updatedAt
}

model Post {
  id        String       @id @default(cuid())
  title     String
  content   String
  excerpt   String?
  thumbnail String?
  published Boolean      @default(true)
  createdAt DateTime     @default(now())
  author    String?      @default("법무사 김형근")
  readTime  Int?         @default(5)
  tags      String?
  updatedAt DateTime     @updatedAt
  viewCount Int          @default(0)
  category  PostCategory
}

model Review {
  id        String   @id @default(cuid())
  title     String
  content   String
  rating    Int      @default(5)
  author    String
  password  String?
  createdAt DateTime @default(now())
  isPublic  Boolean  @default(true)
  updatedAt DateTime @updatedAt
}

model Analytics {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())
}

enum Role {
  USER
  ADMIN
  SUPERADMIN
}

enum LeadStatus {
  PENDING
  CONTACTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PostCategory {
  REHAB
  BANKRUPTCY
  SUCCESS_STORY
  COLUMN
}
